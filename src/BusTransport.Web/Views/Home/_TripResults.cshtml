@model IReadOnlyList<BusTransport.Core.Models.Trip>

<section class="section">
@if (!Model.Any())
{
  <div class="empty">Няма намерени автобуси за избрания маршрут.</div>
}
else
{
  <div class="result-list">
  @foreach (var trip in Model)
  {
    <article class="result-card">
      <div>
        <strong>@trip.DepartureCity.CityName - @trip.ArrivalCity.CityName</strong>
        <span>@trip.Carrier.Name · @trip.TripCode · автобус @trip.BusNumber</span>
      </div>
      <div><b>@trip.DepartureTime.ToString("HH:mm")</b><small>тръгване</small></div>
      <div><b>@trip.ArrivalTime.ToString("HH:mm")</b><small>пристигане</small></div>
      <div><b>@trip.Duration.ToString(@"h\:mm") ч.</b><small>@(trip.HasIntermediateStops ? trip.IntermediateStops : "директен")</small></div>
      <div><b>@trip.Price.ToString("0") лв.</b><small>@trip.AvailableSeats места</small></div>
      <a class="primary small" asp-controller="Tickets" asp-action="Book" asp-route-tripId="@trip.Id">Резервирай</a>
    </article>
  }
  </div>
}
</section>
