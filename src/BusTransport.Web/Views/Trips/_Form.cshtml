@model Trip
<div asp-validation-summary="ModelOnly" class="validation"></div>
<div class="form-grid">
  <label>Код на пътуване<input asp-for="TripCode" required /></label>
  <label>Превозвач<select asp-for="CarrierId" asp-items="ViewBag.CarrierId"></select></label>
  <label>Начален град<select asp-for="DepartureCityId" asp-items="ViewBag.DepartureCityId"></select></label>
  <label>Краен град<select asp-for="ArrivalCityId" asp-items="ViewBag.ArrivalCityId"></select></label>
  <label>Тръгване<input asp-for="DepartureTime" type="datetime-local" /></label>
  <label>Пристигане<input asp-for="ArrivalTime" type="datetime-local" /></label>
  <label>Цена (лв.)<input asp-for="Price" type="number" step="0.01" /></label>
  <label>Свободни места<input asp-for="AvailableSeats" type="number" /></label>
  <label>Автобус №<input asp-for="BusNumber" /></label>
  <label>Платформа<input asp-for="Platform" /></label>
  <label>Статус<select asp-for="Status"><option>По разписание</option><option>Закъснял</option><option>Отменен</option><option>Тръгнал</option><option>Пристигнал</option></select></label>
  <label class="check"><input asp-for="HasIntermediateStops" /> Има междинни спирки</label>
  <label class="wide">Междинни спирки<input asp-for="IntermediateStops" /></label>
</div>
<button class="primary" type="submit">Запази</button>
<a class="secondary" asp-action="Index">Отказ</a>
