@model BusTransport.Core.Models.Ticket
@{ ViewData["Title"] = "Изтриване"; }
<section class="page-head compact"><span class="eyebrow">ПОТВЪРЖДЕНИЕ</span><h1>Да изтрия ли билет @Model.TicketCode?</h1></section>
<form asp-action="Delete" method="post" class="form-page">
  <input asp-for="Id" type="hidden" />
  <p>Това ще премахне билета от системата.</p>
  <button class="primary">Изтрий</button>
  <a class="secondary" asp-action="Index">Отказ</a>
</form>
