@model BusTransport.Core.Models.Ticket
@{ ViewData["Title"] = "Потвърждение"; }

<section class="page-head">
  <span class="eyebrow">ГОТОВО</span>
  <h1>Билетът е създаден успешно</h1>
  <p>Номер на билет: <strong>@Model.TicketCode</strong></p>
  <a class="primary" asp-action="Details" asp-route-id="@Model.Id">Виж билета</a>
</section>
