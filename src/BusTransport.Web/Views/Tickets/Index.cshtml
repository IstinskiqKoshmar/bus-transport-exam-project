@model IEnumerable<BusTransport.Core.Models.Ticket>
@{ ViewData["Title"] = "Моите билети"; }

<section class="page-head compact">
  <span class="eyebrow">БИЛЕТИ И РЕЗЕРВАЦИИ</span>
  <h1>Моите билети</h1>
  <p>Списък с резервирани, платени и използвани билети.</p>
</section>

<section class="section">
  <a class="primary small" asp-action="Create">Добави билет</a>
  <div class="table-wrap">
    <table>
      <thead><tr><th>Код</th><th>Пътник</th><th>Маршрут</th><th>Дата</th><th>Място</th><th>Статус</th><th>Цена</th><th></th></tr></thead>
      <tbody>
      @foreach (var ticket in Model)
      {
        <tr>
          <td>@ticket.TicketCode</td>
          <td>@ticket.Passenger.FullName</td>
          <td>@ticket.Trip.DepartureCity.CityName - @ticket.Trip.ArrivalCity.CityName</td>
          <td>@ticket.Trip.DepartureTime.ToString("dd.MM.yyyy HH:mm")</td>
          <td>@ticket.SeatNumber</td>
          <td>@ticket.Status</td>
          <td>@ticket.TotalPrice.ToString("0.00") лв.</td>
          <td><a asp-action="Details" asp-route-id="@ticket.Id">Детайли</a> · <a asp-action="Edit" asp-route-id="@ticket.Id">Редакция</a> · <a asp-action="Delete" asp-route-id="@ticket.Id">Изтрий</a></td>
        </tr>
      }
      </tbody>
    </table>
  </div>
</section>
